function get_connectors_list() {
	for edid in /sys/class/drm/card*-*-*/; do
		case "${edid}" in *-Writeback-*) continue ;; *) ;; esac
		edid="${edid%/}"      # Remove trailing slash
		edid="${edid##*/}"    # Get basename
		echo "${edid#card*-}" # Remove card*- prefix using glob pattern
	done
}
function get_enabled_connectors_list() {
	for edid in /sys/class/drm/card*-*-*/; do
		case "${edid}" in *-Writeback-*) continue ;; *) ;; esac
		if [[ "$(<"${edid}"/enabled)" == "disabled" ]]; then continue; fi
		edid="${edid%/}"      # Remove trailing slash
		edid="${edid##*/}"    # Get basename
		echo "${edid#card*-}" # Remove card*- prefix using glob pattern
	done
}
function KDE::get_display_configuration() {
	if [[ -z ${DEFAULT_STREAM_DISPLAY} ]] || [[ -z ${DEFAULT_SEAT_DISPLAY} ]]; then
		log::warning "To override which monitor is used for streaming, please set DEFAULT_STREAM_DISPLAY and DEFAULT_SEAT_DISPLAY"
		log::warning "Automation is a little fragile at the moment"
	fi
}
function KDE::do() {
	if [[ -z ${_stream_display} ]]; then
		log::error "Stream display not set!"
		return 0
	fi
	log::info "Enabling ${_stream_display}"
	kscreen-doctor output."${_stream_display}".enable

	log::info "Configuring ${_stream_display} for streaming"
	adjusted_hz=$(printf '%.0f' "${_client_refresh_rate}")

	# Determine HDR mode
	HDR_MODE=disable
	if [[ ${_client_hdr} == "true" ]]; then
		HDR_MODE="enable"
	fi
	log::info "$([[ ${_client_hdr} == "true" ]] && echo "Enabling" || echo "Disabling") HDR for ${_stream_display}" || true
	log::info "Setting '${_stream_display}' to ${_client_width}x${_client_height}@${adjusted_hz}"
	log::info "$(kscreen-doctor output."${_stream_display}".mode."${_client_width}"x"${_client_height}"@"${adjusted_hz}")"
	log::info "Configuring HDR/WCG for ${_stream_display}"
	log::info "$(kscreen-doctor output."${_stream_display}".hdr."${HDR_MODE}" output."${_stream_display}".wcg."${HDR_MODE}")"

	# Disable all other displays
	log::info "Waiting before disabling other displays..."
	sleep 1
	local -a all_connectors
	mapfile -t all_connectors < <(get_connectors_list) || true
	for connector in "${all_connectors[@]}"; do
		if [[ ${connector} != "${_stream_display}" ]]; then
			log::info "Disabling ${connector}"
			log::info "$(kscreen-doctor output."${connector}".disable))"
		fi
	done
}
function KDE::undo() {
	log::info "Restoring ${_seat_display} to default configuration"
	log::info "Enabling ${_seat_display}"
	kscreen-doctor output."${_seat_display}".enable
	log::info "Switching ${_seat_display} to ${_seat_resolution}@${_seat_refresh_rate}"
	kscreen-doctor output."${_seat_display}".mode."${_seat_resolution}"@"${_seat_refresh_rate}"
	log::info "Configuring HDR/WCG/VRR for ${_seat_display}"
	kscreen-doctor output."${_seat_display}".hdr."${_default_hdr}" output."${_seat_display}".wcg."${_default_hdr}" output."${_seat_display}".vrrpolicy."${_default_vrr_mode}"

	# Cache connectors list to avoid repeated subshell spawning
	local -a all_connectors
	mapfile -t all_connectors < <(get_connectors_list) || true

	# Enable and configure other connectors
	for connector in "${all_connectors[@]}"; do
		if [[ ${connector} == "${_stream_display}" ]] && [[ ${_stream_display} != "${_seat_display}" ]]; then
			log::info "Skipping stream display ${connector}"
			continue
		fi
		if [[ ${connector} != "${_seat_display}" ]]; then
			log::info "Enabling ${connector}"
			log::info "$(kscreen-doctor output."${connector}".enable)"
		fi
	done
	# Disable stream output last
	if [[ ${_stream_display} != "${_seat_display}" ]]; then
		log::info "Waiting before disabling stream display..."
		sleep 1
		log::info "Disabling ${_stream_display}"
		log::info "$(kscreen-doctor output."${_stream_display}".disable)"
	else
		log::info "Not doing anything else because Stream Display isn't different than Seat display (${_stream_display} != ${_seat_display})"
	fi
}
function niri::get_display_configuration() {
	_json_display_config=$(niri msg -j outputs)
	mapfile -t outputs_list < <(echo "${_json_display_config}" | jq -r '.[] | .name')
	log::info "outputs_list: ${outputs_list[*]}"
	if [[ "$(echo "${_json_display_config}" | jq 'has("'"${_stream_display}"'")')" == "true" ]]; then
		_has_stream_display=true
	fi
	if [[ "$(echo "${_json_display_config}" | jq 'has("'"${_seat_display}"'")')" == "true" ]]; then
		_has_seat_display=true
	fi
	log::info "Stream Display Present: ${_has_stream_display}"
	log::info "Seat   Display Present: ${_has_seat_display}"
}
function niri::do() {
	# Niri is fickle, let's be extremely explicit about the behavior we want.
	if [[ ${_has_stream_display} == "true" ]] && [[ ${_has_seat_display} == "false" ]]; then
		# Only the stream display is present
		log::info "Only stream display is present, moving over to stream display ${_stream_display}"
		niri msg output "${_stream_display}" on
		niri msg output "${_stream_display}" custom-mode "${_client_width}x${_client_height}@${_client_refresh_rate}"
		niri msg output "${_stream_display}" position "0x0"
	elif [[ ${_has_stream_display} == "false" ]] && [[ ${_has_seat_display} == "true" ]]; then
		# Only the seat display is present
		log::info "Only seat display is present, moving over to seat display ${_seat_display}"
		niri msg output "${_seat_display}" on
		niri msg output "${_seat_display}" custom-mode "${_client_width}x${_client_height}@${_client_refresh_rate}"
		niri msg output "${_seat_display}" position "0x0"
	elif [[ ${_has_stream_display} == "true" ]] && [[ ${_has_seat_display} == "true" ]]; then
		# Both displays are present
		log::info "Both displays are present, switching over to stream display ${_stream_display}"
		niri msg output "${_stream_display}" on
		niri msg output "${_stream_display}" custom-mode "${_client_width}x${_client_height}@${_client_refresh_rate}"
		niri msg output "${_stream_display}" position "0x0"
		# sleep 2
		log::info "Disabling ${_seat_display}"
		niri msg output "${_seat_display}" off
		# sleep 0.5
		niri msg action focus-monitor "${_stream_display}"
		niri msg action focus-workspace 1
	elif [[ ${_has_stream_display} == "false" ]] && [[ ${_has_seat_display} == "false" ]]; then
		# No display are present
		log::warning "No display has been found, automation skipped!"
	fi
	log::info "Done"
}
function niri::undo() {
	# NOTE: Niri+sunshine crashes a lot on older sunshine releases.
	# I've confirmed that sunshine-git v2026.218.44016-1 works properly
	# Niri is fickle, let's be extremely explicit about the behavior we want.
	if [[ ${_has_stream_display} == "true" ]] && [[ ${_has_seat_display} == "false" ]]; then
		# Only the stream display is present
		log::info "Only stream display is present, moving over to stream display ${_stream_display}"
		niri msg output "${_stream_display}" on
		niri msg output "${_stream_display}" mode "${_seat_resolution}@60"
		niri msg output "${_stream_display}" position "0x0"
	elif [[ ${_has_stream_display} == "false" ]] && [[ ${_has_seat_display} == "true" ]]; then
		# Only the seat display is present
		log::info "Only seat display is present, moving over to seat display ${_seat_display}"
		niri msg output "${_seat_display}" on
		niri msg output "${_seat_display}" mode "${_seat_resolution}"@"${_seat_refresh_rate}"
		niri msg output "${_seat_display}" position "0x0"
	elif [[ ${_has_stream_display} == "true" ]] && [[ ${_has_seat_display} == "true" ]]; then
		# Both displays are present
		log::info "Both displays are present, switching over to seat display ${_seat_display}"
		niri msg output "${_seat_display}" on
		niri msg output "${_seat_display}" mode "${_seat_resolution}"@"${_seat_refresh_rate}"
		niri msg output "${_seat_display}" position "0x0"
		# sleep 2
		log::info "Disabling ${_stream_display}"
		niri msg output "${_stream_display}" off
		niri msg action focus-monitor "${_seat_display}"
		niri msg action focus-workspace 1
	elif [[ ${_has_stream_display} == "false" ]] && [[ ${_has_seat_display} == "false" ]]; then
		# No display are present
		log::warning "No display has been found, automation skipped!"
	fi
	log::info "Done"
}
generic::get_display_configuration() {
	if ! command -v wlr-randr &>/dev/null; then
		log::warning "wlr-randr not available, cannot detect display configuration"
		_has_stream_display=false
		_has_seat_display=false
		return 1
	fi

	if ! command -v jq &>/dev/null; then
		log::warning "jq not available, cannot parse wlr-randr output"
		_has_stream_display=false
		_has_seat_display=false
		return 1
	fi

	_json_display_config=$(wlr-randr --json 2>/dev/null)
	if [[ -z "${_json_display_config}" ]]; then
		log::warning "wlr-randr --json returned empty output"
		_has_stream_display=false
		_has_seat_display=false
		return 1
	fi

	if echo "${_json_display_config}" | jq -e "has(\"${_stream_display}\")" &>/dev/null; then
		_has_stream_display=true
	fi
	if echo "${_json_display_config}" | jq -e "has(\"${_seat_display}\")" &>/dev/null; then
		_has_seat_display=true
	fi
	log::info "Stream Display Present: ${_has_stream_display}"
	log::info "Seat   Display Present: ${_has_seat_display}"
}
generic::detect_session() {
	local session_type
	# Get systemd session type
	# FIXME: hyprland doesn't show as "active", but as a seat on tty3
	# user_sessions=$(loginctl list_sessions | grep "$USER")
	if [[ -n ${XDG_SESSION_TYPE} ]]; then
		session_type="${XDG_SESSION_TYPE}"
	else
		# shellcheck disable=SC2312
		log::warning "XDG_SESSION_TYPE is not set, using best-effort detection using loginctl"
		if command -v loginctl 2>&1; then
			session_type=$(loginctl 2>/dev/null show-session "$(awk '/tty/ {print $1}' <(loginctl list-sessions | grep "${USER}" | grep -v manager))" -p Type | awk -F= '{print $2}')
		else
			log::warning "loginctl not available, cannot autodetect"
		fi

	fi

	if [[ -n ${_session_type} ]]; then
		_session_type="${session_type}"
		return
	else
		environment=$(env)
		if grep -qc "WAYLAND_DISPLAY" <<<"${environment}"; then
			_session_type=wayland
			return
		elif grep -qc "DISPLAY" <<<"${environment}"; then
			_session_type=x11
			return
		fi
	fi
	_session_type "none"
}
generic::wayland::do() {
	if ! command -v wlr-randr &>/dev/null; then
		log::error "wlr-randr not found, cannot configure Wayland outputs"
		return 1
	fi

	log::info "Enabling ${_stream_display} for streaming"
	wlr-randr --output "${_stream_display}" --on

	local adjusted_hz
	adjusted_hz=$(printf '%.0f' "${_client_refresh_rate}")
	log::info "Configuring ${_stream_display} to ${_client_width}x${_client_height}@${adjusted_hz}"
	wlr-randr --output "${_stream_display}" --custom-mode "${_client_width}x${_client_height}@${adjusted_hz}"

	if [[ ${_has_seat_display} == "true" ]]; then
		log::info "Waiting before disabling seat display..."
		sleep 1
		log::info "Disabling ${_seat_display}"
		wlr-randr --output "${_seat_display}" --off
	fi

	log::info "Wayland do complete"
}
generic::wayland::undo() {
	if ! command -v wlr-randr &>/dev/null; then
		log::error "wlr-randr not found, cannot restore Wayland outputs"
		return 1
	fi

	local adjusted_hz
	adjusted_hz=$(printf '%.0f' "${_seat_refresh_rate}")

	if [[ ${_has_stream_display} == "true" ]] && [[ ${_has_seat_display} == "false" ]]; then
		log::info "Only stream display is present, restoring to ${_stream_display}"
		wlr-randr --output "${_stream_display}" --on
		wlr-randr --output "${_stream_display}" --mode "${_seat_resolution}@${adjusted_hz}"
	elif [[ ${_has_stream_display} == "false" ]] && [[ ${_has_seat_display} == "true" ]]; then
		log::info "Only seat display is present, restoring ${_seat_display}"
		wlr-randr --output "${_seat_display}" --on
		wlr-randr --output "${_seat_display}" --mode "${_seat_resolution}@${adjusted_hz}"
	elif [[ ${_has_stream_display} == "true" ]] && [[ ${_has_seat_display} == "true" ]]; then
		log::info "Both displays present, restoring ${_seat_display}"
		wlr-randr --output "${_seat_display}" --on
		wlr-randr --output "${_seat_display}" --mode "${_seat_resolution}@${adjusted_hz}"
		log::info "Waiting before disabling stream display..."
		sleep 1
		log::info "Disabling ${_stream_display}"
		wlr-randr --output "${_stream_display}" --off
	elif [[ ${_has_stream_display} == "false" ]] && [[ ${_has_seat_display} == "false" ]]; then
		log::warning "No display found, restore skipped"
	fi

	log::info "Wayland undo complete"
}
generic::get_x11_display_configuration() {
	if [[ -z ${DISPLAY} ]]; then
		log::warning "DISPLAY is not set, cannot detect x11 display configuration"
		_has_stream_display=false
		_has_seat_display=false
		return 1
	fi

	if ! command -v xrandr &>/dev/null; then
		log::warning "xrandr not available, cannot detect x11 display configuration"
		_has_stream_display=false
		_has_seat_display=false
		return 1
	fi

	local xrandr_output
	xrandr_output=$(xrandr -q 2>/dev/null)
	if [[ -z "${xrandr_output}" ]]; then
		log::warning "xrandr -q returned empty output"
		_has_stream_display=false
		_has_seat_display=false
		return 1
	fi

	if echo "${xrandr_output}" | grep -qP "^${_stream_display}\s+connected"; then
		_has_stream_display=true
	fi
	if echo "${xrandr_output}" | grep -qP "^${_seat_display}\s+connected"; then
		_has_seat_display=true
	fi
	log::info "Stream Display Present: ${_has_stream_display}"
	log::info "Seat   Display Present: ${_has_seat_display}"
}
generic::x11::do() {
	if [[ -z ${DISPLAY} ]]; then
		log::error "DISPLAY not set, cannot configure x11 outputs"
		return 1
	fi

	if ! command -v xrandr &>/dev/null; then
		log::error "xrandr not found, cannot configure x11 outputs"
		return 1
	fi

	log::info "Enabling ${_stream_display} for streaming"
	xrandr --output "${_stream_display}" --auto

	local mode_string="${_client_width}x${_client_height}"
	log::info "Configuring ${_stream_display} to ${mode_string}"
	if xrandr -q 2>/dev/null | grep -qP "^${_stream_display}\s+connected\s+.*${mode_string}"; then
		log::info "Mode ${mode_string} available, using --mode"
		xrandr --output "${_stream_display}" --mode "${mode_string}"
	else
		log::warning "Mode ${mode_string} not in xrandr list, using --auto (preferred mode)"
	fi

	if [[ ${_has_seat_display} == "true" ]]; then
		log::info "Waiting before disabling seat display..."
		sleep 1
		log::info "Disabling ${_seat_display}"
		xrandr --output "${_seat_display}" --off
	fi

	log::info "x11 do complete"
}
generic::x11::undo() {
	if [[ -z ${DISPLAY} ]]; then
		log::error "DISPLAY not set, cannot restore x11 outputs"
		return 1
	fi

	if ! command -v xrandr &>/dev/null; then
		log::error "xrandr not found, cannot restore x11 outputs"
		return 1
	fi

	local adjusted_hz
	adjusted_hz=$(printf '%.0f' "${_seat_refresh_rate}")
	local mode_string="${_seat_resolution}@${adjusted_hz}"

	if [[ ${_has_stream_display} == "true" ]] && [[ ${_has_seat_display} == "false" ]]; then
		log::info "Only stream display is present, restoring to ${_stream_display}"
		xrandr --output "${_stream_display}" --auto
		if xrandr -q 2>/dev/null | grep -qP "^${_stream_display}\s+connected\s+.*${_seat_resolution}"; then
			xrandr --output "${_stream_display}" --mode "${_seat_resolution}"
			xrandr --output "${_stream_display}" --refresh "${adjusted_hz}"
		fi
	elif [[ ${_has_stream_display} == "false" ]] && [[ ${_has_seat_display} == "true" ]]; then
		log::info "Only seat display is present, restoring ${_seat_display}"
		xrandr --output "${_seat_display}" --auto
		if xrandr -q 2>/dev/null | grep -qP "^${_seat_display}\s+connected\s+.*${_seat_resolution}"; then
			xrandr --output "${_seat_display}" --mode "${_seat_resolution}"
			xrandr --output "${_seat_display}" --refresh "${adjusted_hz}"
		fi
	elif [[ ${_has_stream_display} == "true" ]] && [[ ${_has_seat_display} == "true" ]]; then
		log::info "Both displays present, restoring ${_seat_display}"
		xrandr --output "${_seat_display}" --auto
		if xrandr -q 2>/dev/null | grep -qP "^${_seat_display}\s+connected\s+.*${_seat_resolution}"; then
			xrandr --output "${_seat_display}" --mode "${_seat_resolution}"
			xrandr --output "${_seat_display}" --refresh "${adjusted_hz}"
		fi
		log::info "Waiting before disabling stream display..."
		sleep 1
		log::info "Disabling ${_stream_display}"
		xrandr --output "${_stream_display}" --off
	elif [[ ${_has_stream_display} == "false" ]] && [[ ${_has_seat_display} == "false" ]]; then
		log::warning "No display found, restore skipped"
	fi

	log::info "x11 undo complete"
}
function handle_arguments() {
	Handle client resolution override via a command-line parameter
	while [[ $# -gt 0 ]]; do
		case "$1" in
			-r|--res-override)
				if [[ -z "${2:-}" ]]; then
					log::error "Error: --res-override requires a non-empty argument." >&2
					exit 1
				fi
				RES_OVERRIDE="$2"
				shift 2
				;;
				--res-override=*)
				RES_OVERRIDE="${1#*=}"
				shift
				;;
			*)
				POSITIONAL_PARAMS+=("$1")
				shift
				;;
		esac
	done
	if [[ -n "$RES_OVERRIDE" ]]; then
	log::warning "Overriding resolution to '${RES_OVERRIDE}'"
	_client_width="${RES_OVERRIDE%x*}"
	_client_height="${RES_OVERRIDE#*x}"
	unset RES_OVERRIDE
	fi
}

function mainloop() {
	log::info "Global variables at start:
	_seat_resolution=${_seat_resolution}
	_seat_refresh_rate=${_seat_refresh_rate}
	_default_vrr_mode=${_default_vrr_mode}
	_seat_display=${_seat_display}
	_stream_display=${_stream_display}
	_client_height=${_client_height}
	_client_width=${_client_width}
	_client_refresh_rate=${_client_refresh_rate}
	_default_hdr=${_default_hdr}
	XDG_CURRENT_DESKTOP=${XDG_CURRENT_DESKTOP}
	XDG_SESSION_DESKTOP=${XDG_SESSION_DESKTOP}
	AMD_DEBUG=${AMD_DEBUG}
	RADV_PERFTEST=${RADV_PERFTEST}"

	case "${XDG_CURRENT_DESKTOP}" in
	"GNOME" | "KDE" | "niri")
		"${XDG_CURRENT_DESKTOP}::get_display_configuration"
		# "${XDG_CURRENT_DESKTOP}::get_closest_mode"
		"${XDG_CURRENT_DESKTOP}::$1"
		;;
	*)
		if [[ -n ${XDG_CURRENT_DESKTOP} ]]; then
			log::warning "Desktop environment '${XDG_CURRENT_DESKTOP}' has no environment-specific implementations, using generic RANDR-based automation"
		else
			log::warning "XDG_CURRENT_DESKTOP is not set!"
		fi
		generic::detect_session
		if [[ "${_session_type}" == "wayland" ]]; then
			generic::get_display_configuration
		elif [[ "${_session_type}" == "x11" ]]; then
			generic::get_x11_display_configuration
		fi
		generic::"${_session_type}"::"$1"
		;;
	esac
	if [[ ${_stream_display} == "" ]]; then
		log::warning "Could not determine output to stream out!!!"
		exit 0
	fi

	unset _preferred_monitor _session_type _primary _client_height _client_width _refresh
	# log::info "Reminder: If your client gets a black screen, try rebooting the host"
}
handle_arguments "$@"
mainloop "$@"
